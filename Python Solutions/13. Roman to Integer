class Solution(object):
    def romanToInt(self, s):
        """
        :type s: str
        :rtype: int
        """
        roman = {
            "I":1, "V": 5,"X":10,"L":50,"C":100,"D":500,"M":1000
        }
        total = 0

        for i in range(len(s)):
            curr = roman[s[i]]
            # print(curr)
            if i+1 < len(s):
                nextVal = roman[s[i+1]]
            else:
                0

            if curr < nextVal:
                total -= curr
            else:
                total += curr
            # print(s[i])


        return total
        
